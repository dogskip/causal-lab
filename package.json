{
  "name": "causal-lab",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Deterministic CRDT network simulation with virtual time",
  "license": "MIT",
  "exports": "./dist/index.js",
  "bin": {
    "causal-lab": "./dist/server.js"
  },
  "files": [
    "dist",
    "schema",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "start": "tsx src/server.ts",
    "bench": "tsx bench/bench.ts",
    "repl": "tsx src/repl.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@hono/node-server": "2.0.10",
    "hono": "4.12.30"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.13",
    "eslint": "10.7.0",
    "fast-check": "^3.23.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
